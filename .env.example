# ============================================================
# Higgsfield AI Credentials
# ============================================================
# Get these from https://platform.higgsfield.ai → Settings → API Keys
# Your key is in KEY_ID:KEY_SECRET format — paste the whole thing here.
# Example: HIGGSFIELD_API_KEY=hf_abc123:secretXYZ789
HIGGSFIELD_API_KEY=YOUR_KEY_ID:YOUR_KEY_SECRET

# ============================================================
# Meta / Instagram Graph API Credentials
# ============================================================

# Your Instagram Business account numeric ID.
# How to find it:
#   1. Go to https://developers.facebook.com/tools/explorer/
#   2. Select your app and add permission: instagram_basic
#   3. Run: GET /me/accounts  → find your page → copy the id
#   4. Then: GET /{page_id}?fields=instagram_business_account
#   5. Copy the instagram_business_account.id value
IG_USER_ID=YOUR_IG_BUSINESS_ACCOUNT_ID

# Long-lived Meta User Access Token (~60 days, must include permissions below).
# Required permissions: instagram_basic, instagram_content_publish, pages_read_engagement
#
# How to get a long-lived token:
#   1. Open https://developers.facebook.com/tools/explorer/
#   2. Select your app, add the permissions above, click "Generate Access Token"
#   3. Copy the short-lived token (valid 1 hour)
#   4. Exchange for long-lived (60 days) via:
#      GET https://graph.facebook.com/v25.0/oauth/access_token
#          ?grant_type=fb_exchange_token
#          &client_id={APP_ID}
#          &client_secret={APP_SECRET}
#          &fb_exchange_token={SHORT_LIVED_TOKEN}
#   5. Paste the returned access_token value here.
#
# To refresh before expiry (do this every ~50 days to stay logged in):
#   Run the same fb_exchange_token exchange with your current long-lived token.
#   Meta will return a fresh 60-day token.
IG_ACCESS_TOKEN=YOUR_LONG_LIVED_META_ACCESS_TOKEN

# ============================================================
# Post Settings
# ============================================================
# Caption that will appear on every post. Include hashtags here.
POST_CAPTION=Your caption here 🚀 #AI #contentcreation #scales10x
